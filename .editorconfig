# Universal, stack-neutral rules only — no language-specific indent widths (this template
# is language-agnostic). Consistent line endings + final newlines keep diffs clean, which
# the byte-identical golden-output diffing in /verify-refactor relies on.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.md]
trim_trailing_whitespace = false  # preserve Markdown hard line breaks (two trailing spaces)
